<Page x:Class="LSPDFRModManager.Views.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Mod Library"
      Background="Transparent">

    <!-- ===============================================================
         FADE-IN ANIMATION (300 ms)
         =============================================================== -->
    <Page.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}" />
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="RootPanel" Opacity="0" Margin="24,8,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===============================================
             HEADER with search bar and settings
             =============================================== -->
        <Grid Grid.Row="0" Margin="4,8,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title row with settings gear -->
            <DockPanel Grid.Row="0">
                <Button DockPanel.Dock="Right"
                        Content="&#x2699;"
                        Style="{StaticResource CloseButton}"
                        Command="{Binding OpenSettingsCommand}"
                        FontSize="18"
                        ToolTip="Settings"
                        VerticalAlignment="Top"
                        Margin="8,0,0,0" />
                <StackPanel>
                    <TextBlock Text="Mod Library"
                               FontSize="24" FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Download, locate, and install LSPDFR plugins"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <!-- Search bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource InputBrush}"
                    CornerRadius="10"
                    Padding="4,0"
                    Margin="0,12,0,0"
                    Height="38">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="&#x1F50D;"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="10,0,6,0" />

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Foreground="#D0D0E0"
                             CaretBrush="#D0D0E0"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Padding="0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ===============================================
             MOD CARDS grouped by Category
             =============================================== -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ModsView}">

                <!-- Category group header + card grid -->
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel Margin="0,0,0,14">
                                                <!-- Category header bar -->
                                                <Border Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="8"
                                                        Padding="14,8"
                                                        Margin="4,4,4,8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </Border>
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ItemsControl.GroupStyle>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- ======= SINGLE MOD CARD ======= -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                Padding="20"
                                Margin="4,4"
                                Width="340">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Mod name (clickable) -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Name}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,4"
                                           Cursor="Hand">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>

                                <!-- Description -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           MaxHeight="50"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,10" />

                                <!-- Version badge -->
                                <Border Grid.Row="2"
                                        Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="v" /><Run Text="{Binding Version, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>

                                <!-- Action buttons -->
                                <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                                    <Button Content="🌐 Download"
                                            Style="{StaticResource OutlinedButton}"
                                            Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,4" />

                                    <Button Content="📄 Details"
                                            Style="{StaticResource OutlinedButton}"
                                            Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,4" />

                                    <Button Content="📂 Install"
                                            Height="36"
                                            Command="{Binding DataContext.LocateInstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,0,4">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </WrapPanel>

                                <!-- Status / Installed badge -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <Border Background="{StaticResource InstalledBrush}"
                                            CornerRadius="10"
                                            Padding="10,4"
                                            Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#x2713; Installed"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===============================================
             BOTTOM STATUS BAR
             =============================================== -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                CornerRadius="8"
                Padding="12,8"
                Margin="4,12,4,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Page>
