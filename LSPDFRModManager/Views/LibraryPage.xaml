<Page x:Class="LSPDFRModManager.Views.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Mod Library"
      Background="Transparent">

    <!-- ═══════════════════════════════════════════════════════════
         FADE-IN ANIMATION (300 ms)
         ═══════════════════════════════════════════════════════════ -->
    <Page.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}" />
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="RootPanel" Opacity="0" Margin="24,8,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER
             ═══════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="4,8,0,16">
            <TextBlock Text="Mod Library"
                       FontSize="24" FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="Download, locate, and install LSPDFR plugins"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════
             MOD CARD GRID (2 columns)
             ═══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- ═══ SINGLE MOD CARD ═══ -->
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                Padding="20"
                                Margin="4,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- ── Mod name ── -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Name}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,4" />

                                <!-- ── Description ── -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />

                                <!-- ── Version badge ── -->
                                <Border Grid.Row="2"
                                        Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="v" /><Run Text="{Binding Version, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>

                                <!-- ── Action buttons ── -->
                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                    <!-- Download: opens LCPDFR page in browser -->
                                    <Button Content="🌐 Download"
                                            Style="{StaticResource OutlinedButton}"
                                            Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,0" />

                                    <!-- Locate &amp; Install: file dialog → install -->
                                    <Button Content="📂 Locate &amp; Install"
                                            Height="36"
                                            Command="{Binding DataContext.LocateInstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- ── Status / Installed badge ── -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <!-- Green "Installed" pill badge -->
                                    <Border Background="{StaticResource InstalledBrush}"
                                            CornerRadius="10"
                                            Padding="10,4"
                                            Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="✓ Installed"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>

                                    <!-- Per-card status message (progress / errors) -->
                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════
             BOTTOM STATUS BAR
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                CornerRadius="8"
                Padding="12,8"
                Margin="4,12,4,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Page>
