<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         COLOR PALETTE
         Central place for every color used across the application.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

    <!-- Background gradient -->
    <Color x:Key="BgTop">#1E1040</Color>
    <Color x:Key="BgBottom">#0D0E1F</Color>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="CardBrush"       Color="#1A1C2E" />
    <SolidColorBrush x:Key="InputBrush"       Color="#252740" />
    <SolidColorBrush x:Key="InputHoverBrush"  Color="#323658" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#222540" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#5B8CFF" />
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#7BA3FF" />
    <SolidColorBrush x:Key="AccentPressedBrush"  Color="#4A73D4" />
    <SolidColorBrush x:Key="AccentDisabledBrush" Color="#2A3A5C" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="White" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0BB" />
    <SolidColorBrush x:Key="TextMutedBrush"     Color="#6B6D80" />
    <SolidColorBrush x:Key="TextDisabledBrush"  Color="#555770" />

    <!-- Validation -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="ErrorBrush"      Color="#FF6B6B" />
    <SolidColorBrush x:Key="InstalledBrush"  Color="#2ECC71" />

    <!-- Separator -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#2A2D45" />

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         PAGE GRADIENT
         Shared dark gradient applied as Background on every page.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <LinearGradientBrush x:Key="PageGradient" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="{StaticResource BgTop}"    Offset="0" />
        <GradientStop Color="{StaticResource BgBottom}" Offset="1" />
    </LinearGradientBrush>

    <!-- ===============================================================
         PRIMARY BUTTON
         White pill shape (24 px radius), 48 px tall.
         Used for the main CTA ("Weiter", "Add Local Mod").
         150 ms smooth hover color transition.
         =============================================================== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height"          Value="48" />
        <Setter Property="FontSize"        Value="15" />
        <Setter Property="FontWeight"      Value="Bold" />
        <Setter Property="Foreground"      Value="#1A1A2E" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            CornerRadius="24"
                            Padding="28,0"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <SolidColorBrush Color="White" />
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#F0F0F0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="White" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#DADAF0" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bg"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="White" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#3A3D55" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         SECONDARY BUTTON
         Subtle dark surface, rounded 8 px.
         For lower-priority actions ("Open Website", etc.).
         Also used as the implicit default button style.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height"          Value="36" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="Foreground"      Value="{StaticResource AccentBrush}" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            Padding="16,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#2A2E52" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1C1F38" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{StaticResource AccentDisabledBrush}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit default â€” every unstyled Button gets SecondaryButton -->
    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}" />
    <!-- ===============================================================
         OUTLINED BUTTON
         Accent-colored border, transparent background.
         Used for secondary actions like "Download" on mod cards.
         =============================================================== -->
    <Style x:Key="OutlinedButton" TargetType="Button">
        <Setter Property="Height"          Value="36" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="FontWeight"      Value="SemiBold" />
        <Setter Property="Foreground"      Value="{StaticResource AccentBrush}" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Padding="16,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1A2040" />
                            <Setter TargetName="Bg" Property="BorderBrush"
                                    Value="{StaticResource AccentHoverBrush}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#151838" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="BorderBrush"
                                    Value="{StaticResource AccentDisabledBrush}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         INPUT BUTTON
         Small accent button that sits inside the composite file-input.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <Style x:Key="InputButton" TargetType="Button">
        <Setter Property="Height"          Value="34" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="FontWeight"      Value="SemiBold" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="9"
                            Padding="14,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{StaticResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         MODERN TEXTBOX
         Rounded 12 px, dark background #2A2D45,
         blue border-glow (#5B8CFF) on focus.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <Style TargetType="TextBox">
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="Foreground"      Value="#D0D0E0" />
        <Setter Property="CaretBrush"      Value="#D0D0E0" />
        <Setter Property="SelectionBrush"  Value="{StaticResource AccentBrush}" />
        <Setter Property="Padding"         Value="14,12" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Border"
                            Background="{StaticResource InputBrush}"
                            CornerRadius="12"
                            BorderBrush="Transparent"
                            BorderThickness="1.5"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource InputHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#5B8CFF"
                                                      BlurRadius="12"
                                                      ShadowDepth="0"
                                                      Opacity="0.35" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         DARK CHECKBOX
         Custom box + check mark styled for dark surfaces.
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="Cursor"     Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box" Width="20" Height="20"
                                CornerRadius="5"
                                Background="{StaticResource InputBrush}"
                                BorderBrush="#3A3D55" BorderThickness="1.5"
                                Margin="0,0,10,0"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="Check"
                                       Text="âœ“" FontSize="13" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background"
                                    Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Check" Property="Visibility"
                                    Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

<!-- ═══════════════════════════════════════════════════════════
         CLOSE BUTTON
         Small X button for the custom borderless title bar.
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="CloseButton" TargetType="Button">
        <Setter Property="Width"           Value="32" />
        <Setter Property="Height"          Value="32" />
        <Setter Property="Content"         Value="?" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="Foreground"      Value="#6B6D80" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#2A2D45" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1E2040" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
