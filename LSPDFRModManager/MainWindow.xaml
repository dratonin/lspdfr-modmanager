<Window x:Class="LSPDFRModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LSPDFR Mod Manager"
        Width="780" Height="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer border provides drop shadow in the transparent margin area -->
    <Border Margin="10" CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>

        <!-- Inner border clips content to rounded shape and provides gradient -->
        <Border CornerRadius="16" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#1E1040" Offset="0" />
                    <GradientStop Color="#0D0E1F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Topographic contour line overlay (~8% opacity) -->
                <Canvas IsHitTestVisible="False" Opacity="0.08">
                    <Path Stroke="White" StrokeThickness="0.8"
                          Data="M 0,140 Q 190,100 380,140 Q 570,180 760,140" />
                    <Path Stroke="White" StrokeThickness="0.7"
                          Data="M 0,165 Q 210,128 380,165 Q 550,202 760,165" />
                    <Path Stroke="White" StrokeThickness="0.6"
                          Data="M 0,190 Q 230,158 380,190 Q 530,222 760,190" />
                    <Path Stroke="White" StrokeThickness="0.7"
                          Data="M 0,280 Q 170,248 380,280 Q 590,312 760,280" />
                    <Path Stroke="White" StrokeThickness="0.6"
                          Data="M 0,305 Q 200,275 380,305 Q 560,335 760,305" />
                    <Path Stroke="White" StrokeThickness="0.5"
                          Data="M 0,330 Q 230,303 380,330 Q 530,357 760,330" />
                    <Path Stroke="White" StrokeThickness="0.6"
                          Data="M 0,400 Q 180,372 380,400 Q 580,428 760,400" />
                    <Path Stroke="White" StrokeThickness="0.5"
                          Data="M 0,425 Q 210,400 380,425 Q 550,450 760,425" />
                    <Path Stroke="White" StrokeThickness="0.5"
                          Data="M 0,455 Q 240,433 380,455 Q 520,477 760,455" />
                </Canvas>

                <!-- Close button (top-right corner of the card) -->
                <Button Style="{StaticResource CloseButton}"
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Panel.ZIndex="1" />

                <!-- Page host frame -->
                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent" />
            </Grid>
        </Border>
    </Border>
</Window>
